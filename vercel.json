{
  "buildCommand": "npm run build",
  "outputDirectory": ".vercel/output/static",
  "installCommand": "npm install",
  "redirects": [
    { "source": "/urunler/", "destination": "/urunler", "permanent": true },
    { "source": "/hakkimizda/", "destination": "/hakkimizda", "permanent": true },
    { "source": "/iletisim/", "destination": "/iletisim", "permanent": true },
    { "source": "/kazanlar/", "destination": "/urunler", "permanent": true },
    { "source": "/buhar-kazanlari/", "destination": "/urunler", "permanent": true },
    { "source": "/sicak-su-kazanlari/", "destination": "/urunler", "permanent": true },
    { "source": "/sicak-hava-kazanlari/", "destination": "/urunler", "permanent": true },
    { "source": "/kizgin-su-kazanlari/", "destination": "/urunler", "permanent": true },
    { "source": "/has-serisi/", "destination": "/urunler/has-serisi", "permanent": true },
    { "source": "/kalsedon-serisi/", "destination": "/urunler/kalsedon-serisi", "permanent": true },
    { "source": "/obsidyen-serisi/", "destination": "/urunler/obsidyen-serisi", "permanent": true },
    { "source": "/akuamarin-serisi/", "destination": "/urunler/akuamarin-serisi", "permanent": true },
    { "source": "/turmalin-serisi/", "destination": "/urunler/turmalin-serisi", "permanent": true },
    { "source": "/kuvars-serisi-tek-kulhanli/", "destination": "/urunler/kuvars-serisi-tek-kulhanli", "permanent": true },
    { "source": "/kuvars-serisi-cift-kulhanli/", "destination": "/urunler/kuvars-serisi-cift-kulhanli", "permanent": true },
    { "source": "/kuvars-ng-serisi/", "destination": "/urunler/kuvars-ng-serisi", "permanent": true },
    { "source": "/has-turbo-serisi/", "destination": "/urunler/has-turbo-serisi", "permanent": true },
    { "source": "/has-ng-serisi/", "destination": "/urunler/has-ng-serisi", "permanent": true },
    { "source": "/ametist-serisi/", "destination": "/urunler/ametist-serisi", "permanent": true },
    { "source": "/turkuaz-serisi/", "destination": "/urunler/turkuaz-serisi", "permanent": true },
    { "source": "/oniks-serisi/", "destination": "/urunler/oniks-serisi", "permanent": true },
    { "source": "/kondenser/", "destination": "/urunler/kondenser", "permanent": true },
    { "source": "/anahtar-teslim-sera-isitma-sistemi/", "destination": "/urunler/anahtar-teslim-sera-isitma-sistemi", "permanent": true }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=63072000; includeSubDomains; preload"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    }
  ]
}