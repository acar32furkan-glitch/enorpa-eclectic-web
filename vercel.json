{
  "buildCommand": "npx vite build",
  "outputDirectory": "dist",
  "framework": "vite",
  "cleanUrls": true,
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "redirects": [
    { "source": "/en/", "destination": "/en", "statusCode": 301 },
    { "source": "/ru/", "destination": "/ru", "statusCode": 301 },
    { "source": "/tr/", "destination": "/", "statusCode": 301 },
{ "source": "/en/references", "destination": "/referanslar", "statusCode": 301 },
    { "source": "/ru/references", "destination": "/referanslar", "statusCode": 301 },
    { "source": "/en/steam-boilers", "destination": "/urunler", "statusCode": 301 },
    { "source": "/en/hot-water-boilers", "destination": "/urunler", "statusCode": 301 },
    { "source": "/en/hot-air-boilers", "destination": "/urunler", "statusCode": 301 },
    { "source": "/en/central-heating", "destination": "/urunler", "statusCode": 301 },
    { "source": "/en/superheated-water-boilers", "destination": "/urunler", "statusCode": 301 },
    { "source": "/en/burners", "destination": "/urunler", "statusCode": 301 },
    { "source": "/en/chimneys", "destination": "/urunler", "statusCode": 301 },
    { "source": "/en/condenser", "destination": "/urunler", "statusCode": 301 },
    { "source": "/en/economizer", "destination": "/urunler", "statusCode": 301 },
    { "source": "/en/spare-parts", "destination": "/urunler", "statusCode": 301 },
    { "source": "/en/boiler-control-panel", "destination": "/urunler", "statusCode": 301 },
    { "source": "/en/boiler-automation-system", "destination": "/urunler", "statusCode": 301 },
    { "source": "/en/turnkey-greenhouse-heating-system", "destination": "/urunler", "statusCode": 301 },
    { "source": "/tr/(.*)", "destination": "/$1", "statusCode": 301 }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Strict-Transport-Security", "value": "max-age=31536000; includeSubDomains" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" }
      ]
    }
  ]
}
